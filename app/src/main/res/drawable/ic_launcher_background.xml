<?xml version="1.0" encoding="utf-8"?>
<!-- Redesigned Launcher Background: Atmospheric dark navy/indigo radial glow
     matching the Vision Pro/iOS 18 styling of 1 torch. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Pure black base -->
    <path
        android:fillColor="#000000"
        android:pathData="M0,0h108v108h-108z" />
    <!-- Ambient glowing circle center -->
    <path android:pathData="M54,54m-44,0a44,44 0,1 1,88 0a44,44 0,1 1,-88 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="44"
                android:type="radial">
                <item android:color="#1D274A" android:offset="0.0" />
                <item android:color="#000000" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
