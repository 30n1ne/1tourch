<?xml version="1.0" encoding="utf-8"?>
<!-- Premium Glass Card shape: brighter, sleeker frosted white boundaries
     to ensure it pops elegantly over pure black backgrounds on physical screens. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#14FFFFFF" /> <!-- 8% white opacity glass fill -->
    <stroke
        android:width="1dp"
        android:color="#40FFFFFF" /> <!-- 25% white opacity structural outline -->
    <corners android:radius="28dp" />
</shape>
